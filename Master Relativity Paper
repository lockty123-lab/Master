    TAR = F / (1 - F + 1e-8)
    
    r = np.linspace(0, 150, 300)
    F_avg = np.mean(F)
    alpha_effect = kappa * (1 - F_avg) * np.exp(-r / 40)
    mass_ratio = 1 + alpha_effect
    
    base_transit_weeks = 24.0
    effective_transit_weeks = base_transit_weeks / (1 + 0.15 * np.mean(TAR))
    
    results = {
        'final_F': F[-1],
