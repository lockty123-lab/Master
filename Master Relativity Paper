        'avg_TAR': np.mean(TAR),
        'peak_TAR': TAR.max(),
        'avg_dark_mimic_percent': (mass_ratio.mean() - 1) * 100,
        'shuttle_transit_weeks': effective_transit_weeks,
        'stability_score': np.mean(F > 0.95) * 100
    }
    
    return results


