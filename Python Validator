# ====================== WAVEFORM GENERATORS ======================

def pn_waveform(t, Mc, eta, tc, phi0, delta_4pn=0.0, amp_scale=5e-21):
    """PN-inspired with crude 4PN log deviation term"""
    tau = np.maximum(tc - t, 1e-6)
    f = (1 / (8 * np.pi * tau))**(3/8) / (Mc * 4.925490947e-6)
    phase = phi0 + np.cumsum(2 * np.pi * f * dt)
    log_correction = delta_4pn * np.log(tau / tau[0] + 1e-8) * (t / duration)**2
    phase += log_correction * 0.5
    amp = amp_scale * (f ** (2/3))
    h = amp * np.cos(phase)
    return h, f, phase

def nr_like_ode(t, omega, Mc, eta, delta_4pn=0.0):
    """Orthogonal: Direct ODE integration (NR/PM flavor)"""
    M_geo = Mc * 4.925490947e-6 / eta**0.6
    base = (96 / 5.0) * eta * (M_geo * omega)**(10/3) * omega**2
    high_order = 0.15 * np.log(omega + 1e-8) + delta_4pn * 0.08 * (omega**(2/3))
    return base * (1 + high_order)

def generate_nr_waveform(t, Mc, eta, tc, phi0, delta_4pn=0.0, amp_scale=5e-21):
    """Integrate ODE for frequency, then phase and strain"""
    omega0 = 2 * np.pi * 20.0
    sol = solve_ivp(nr_like_ode, [t[0], t[-1]], [omega0], 
                    args=(Mc, eta, delta_4pn), t_eval=t, 
                    method='RK45', rtol=1e-7, atol=1e-9)
    omega = np.clip(sol.y[0], 1e-6, None)
    phase = phi0 + np.cumsum(omega * dt)
    phase = phase - phase[-1] + 2 * np.pi * 150 * (t[-1] - tc)
    f = omega / (2 * np.pi)
    amp = amp_scale * (f ** (2/3))
    h = amp * np.cos(phase)
    return h, f, phase

