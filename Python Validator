# ====================== FITTING ======================

def fit_pn(t, h_obs, eta, delta_guess=0.0):
    def model(t, Mc, tc, phi0, delta):
        h, _, _ = pn_waveform(t, Mc, eta, tc, phi0, delta_4pn=delta)
        return h
    p0 = [Mc_true*0.98, tc_true*0.95, 0.5, delta_guess]
    bounds = ([Mc_true*0.7, 0, -np.pi, -1.0], [Mc_true*1.3, duration, np.pi, 1.0])
    try:
        popt, _ = curve_fit(model, t, h_obs, p0=p0, bounds=bounds, maxfev=10000)
        return popt
    except:
        return np.array([Mc_true, tc_true, 0.0, 0.0])

def fit_nr(t, h_obs, eta):
    def residual(params):
        Mc, tc, phi0, delta = params
        h_model, _, _ = generate_nr_waveform(t, Mc, eta, tc, phi0, delta_4pn=delta)
        return np.sum((h_model - h_obs)**2)
    
    def delta_only(d):
        return residual([Mc_true*0.98, tc_true*0.95, 0.0, d])
    res_delta = minimize_scalar(delta_only, bounds=(-0.8, 0.8), method='bounded', tol=1e-8)
    best_delta = res_delta.x
    
    def mc_only(mc):
        h_m, _, _ = generate_nr_waveform(t, mc, eta, tc_true*0.95, 0.0, delta_4pn=best_delta)
        return np.sum((h_m - h_obs)**2)
    res_mc = minimize_scalar(mc_only, bounds=(Mc_true*0.7, Mc_true*1.3), method='bounded', tol=1e-8)
    best_mc = res_mc.x
    
    return np.array([best_mc, tc_true*0.95, 0.0, best_delta])

