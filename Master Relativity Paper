import numpy as np


def dark_horse_full_simulation(days=30, F_init=0.85, gamma=0.05, glue_strength=0.12, kappa=4.8):
    t = np.linspace(0, days, 1000)
    dt = t[1] - t[0]
    F = np.zeros_like(t)
    F[0] = F_init
    
    for i in range(1, len(t)):
        dF = -gamma * (1 - F[i-1]) + glue_strength * F[i-1] * (1 - F[i-1])
